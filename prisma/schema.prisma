generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  WAITER
  COOK
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

model Taqueria {
  id             String    @id @default(uuid())
  name           String
  restaurantCode String    @unique
  phone          String?
  address        String?
  city           String?
  state          String?
  createdAt      DateTime  @default(now())

  users          User[]
  products       Product[]
  orders         Order[]
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  password     String
  name         String
  role         UserRole
  createdAt    DateTime   @default(now())

  taqueriaId   String
  taqueria     Taqueria   @relation(fields: [taqueriaId], references: [id])

  waiterOrders Order[] @relation("WaiterOrders")
}

model Product {
  id            String      @id @default(uuid())
  name          String
  price         Float
  imageUrl      String?
  complements   String[]

  createdAt     DateTime    @default(now())

  taqueriaId    String
  taqueria      Taqueria    @relation(fields: [taqueriaId], references: [id])

  items         Item[]
}

model Order {
  id          String      @id @default(uuid())
  tableNumber String
  status      OrderStatus @default(PENDING)
  isUpdated   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  taqueriaId  String
  taqueria    Taqueria    @relation(fields: [taqueriaId], references: [id])

  waiterId    String
  waiter      User        @relation("WaiterOrders", fields: [waiterId], references: [id])

  plates      Plate[]

  @@index([taqueriaId, status])
  @@index([waiterId])
}

model Plate {
  id          String   @id @default(uuid())
  plateNumber Int
  isClosed    Boolean  @default(false)
  createdAt   DateTime @default(now())

  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])

  items       Item[]

  @@index([orderId, plateNumber])
}

model Item {
  id                  String   @id @default(uuid())
  quantity            Int
  selectedComplements String[]
  notes               String?
  isNew               Boolean  @default(false)
  createdAt           DateTime @default(now())

  productId           String
  product             Product  @relation(fields: [productId], references: [id])

  plateId             String
  plate               Plate    @relation(fields: [plateId], references: [id])
}
