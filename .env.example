# TacosManager API — Environment Variables Template
# Copy to .env.development, .env.qa, or .env.production and fill in the values.
# All .env.* files are gitignored. Only .env.example is committed.

# Identifies the active environment (set by startup script or platform)
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/database?schema=public

# JWT signing secret — use a strong random string in production
JWT_SECRET=your-secret-key-change-in-production

# JWT expiration (e.g. 1d, 8h, 30m)
JWT_EXPIRES_IN=1d

# Port the HTTP server listens on
PORT=3000

# HTTP CORS allowed origin — use * for dev/QA, specific URL for production
CORS_ORIGIN=*

# Socket.IO CORS allowed origin — use * for dev/QA, specific URL for production
SOCKET_ORIGIN=*
